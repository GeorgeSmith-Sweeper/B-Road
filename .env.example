# =============================================================================
# B-Road Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# Usage: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=curvature
POSTGRES_PASSWORD=your_secure_password_here

# Full database URL (constructed from above, or override directly)
DATABASE_URL=postgresql://curvature:your_secure_password_here@db:5432/curvature

# -----------------------------------------------------------------------------
# Mapbox Configuration
# -----------------------------------------------------------------------------
# Required for map display - get token from https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# URL for frontend to reach the API
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# OSRM Routing Configuration
# -----------------------------------------------------------------------------
# Region name matching Geofabrik (e.g., california, new-york, us)
# Use "us" for full US routing (cross-state), or a state name for single-state
OSRM_REGION=california

# OSRM backend URL (used by FastAPI to reach OSRM)
OSRM_URL=http://osrm:5000

# Request timeout in seconds
OSRM_TIMEOUT=30

# -----------------------------------------------------------------------------
# Clerk Authentication (Optional)
# -----------------------------------------------------------------------------
# Create a Clerk app at https://clerk.com and enable Email/Password + Google login
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Clerk Frontend API URL (required for backend JWT verification)
# Find this in your Clerk Dashboard under API Keys
CLERK_ISSUER=https://your-app.clerk.accounts.dev

# Auth page routes (defaults)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# -----------------------------------------------------------------------------
# Optional: Test Database (used by docker-compose.test.yml)
# -----------------------------------------------------------------------------
# TEST_DATABASE_URL=postgresql://curvature_test:test_password@db-test:5432/curvature_test
